# ===========================================
# Catapult Creator Bot Configuration
# ===========================================

# Auth - EVM wallet private key (with 0x prefix)
EVM_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# API endpoint
API_URL=https://api.catapult.trade/graphql

# Token creation defaults
# Rank: Public (required for package credits)
TOKEN_RANK=Public
# Mode: Slow | Fast | Flash | Crack | Mayhem
TOKEN_MODE=Mayhem
# Price mode: One | Ten | Hundred | FiveHundred
TOKEN_PRICE_MODE=FiveHundred

# Scheduling (24h format, UTC)
# Bot will spread token creation between these hours
SPREAD_START_HOUR=0
SPREAD_END_HOUR=23
# Timezone for day boundary calculation
TIMEZONE=UTC

# Logging: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
